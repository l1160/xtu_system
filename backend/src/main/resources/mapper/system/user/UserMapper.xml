<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xtu.system.modules.system.user.mapper.UserMapper">

    <resultMap id="UserEntityMap" type="com.xtu.system.modules.system.user.entity.UserEntity">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password_hash" property="passwordHash"/>
        <result column="real_name" property="realName"/>
        <result column="status" property="status"/>
    </resultMap>

    <select id="selectUserEntityByUsername" resultMap="UserEntityMap">
        SELECT
            id,
            username,
            password_hash,
            real_name,
            status
        FROM sys_user
        WHERE username = #{username} AND deleted = 0
        LIMIT 1
    </select>

    <update id="updateLastLoginAt">
        UPDATE sys_user
        SET
            last_login_at = NOW(),
            updated_at = NOW()
        WHERE id = #{id} AND deleted = 0
    </update>
</mapper>
